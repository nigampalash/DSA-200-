class Solution {
    public int maxProfit(int[] prices) {
        
        int minPrice = Integer.MAX_VALUE;
        int maxProfit = 0;
        
        for (int price : prices) {
            
            // Update minimum buying price
            if (price < minPrice) {
                minPrice = price;
            }
            
            // Calculate profit
            int profit = price - minPrice;
            
            // Update maximum profit
            if (profit > maxProfit) {
                maxProfit = profit;
            }
        }
        
        return maxProfit;
    }
}
