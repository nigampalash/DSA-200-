class Solution {
    
    public int firstMissingPositive(int[] nums) {
        
        int n = nums.length;
        
        for (int i = 0; i < n; i++) {
            
            // Keep swapping until current number
            // reaches correct position
            while (
                nums[i] > 0 &&
                nums[i] <= n &&
                nums[i] != nums[nums[i] - 1]
            ) {
                
                int correct = nums[i] - 1;
                
                int temp = nums[i];
                nums[i] = nums[correct];
                nums[correct] = temp;
            }
        }
        
        // First mismatch
        for (int i = 0; i < n; i++) {
            
            if (nums[i] != i + 1) {
                return i + 1;
            }
        }
        
        return n + 1;
    }
}
